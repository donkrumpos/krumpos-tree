---
import { getCollection } from 'astro:content';

interface Props {
  personId: string;
}

const { personId } = Astro.props;
const allPeople = await getCollection('people');

// Build a lookup by id
const byId = new Map(allPeople.map(p => [p.data.id, p]));

// Walk the parent chain to build breadcrumbs
interface Crumb {
  name: string;
  slug: string;
}

const crumbs: Crumb[] = [];
let currentId = personId;
const visited = new Set<string>();

while (currentId && !visited.has(currentId)) {
  visited.add(currentId);
  const person = byId.get(currentId);
  if (!person) break;

  crumbs.unshift({
    name: person.data.name,
    slug: `${person.data.surname}/${person.data.id}`,
  });

  // Follow first linked parent (paternal line by convention)
  const firstParent = (person.data.linked_parents || [])[0];
  if (firstParent) {
    // linked_parents stores "Surname/id" — extract the id part
    const parentId = firstParent.split('/').pop() || '';
    currentId = parentId;
  } else {
    break;
  }
}
---
{crumbs.length > 1 && (
  <nav class="text-sm text-[var(--color-muted)] mb-4">
    {crumbs.map((crumb, i) => (
      <>
        {i > 0 && <span class="mx-1">&rsaquo;</span>}
        {i === crumbs.length - 1 ? (
          <span class="text-[var(--color-ink)]">{crumb.name}</span>
        ) : (
          <a href={`/person/${crumb.slug}`} class="text-[var(--color-muted)] hover:text-[var(--color-accent)]">{crumb.name}</a>
        )}
      </>
    ))}
  </nav>
)}
