---
import BaseLayout from '../layouts/BaseLayout.astro';
import ancestorsData from '../data/ancestors.json';
import placesData from '../data/places.json';

type AncestorRecord = {
  id: string;
  slug: string;
  name: string;
  surname: string;
  birth: string;
  death: string;
  birth_place: string;
  death_place: string;
  generation: number;
  gender: string;
};

type PlaceRecord = {
  lat: number | null;
  lon: number | null;
  display_name?: string;
  source?: string;
};

const ancestors = ancestorsData as AncestorRecord[];
const places = placesData as Record<string, PlaceRecord>;

// Deterministic surname palette — order matters so colors are stable across builds
const palette = [
  '#8b6f4e', // accent brown
  '#2e5d3a', // forest green
  '#7a3b2e', // brick red
  '#4a5d7e', // dusk blue
  '#a06b2e', // burnt orange
  '#3b6a6a', // teal
  '#7d5a8e', // muted purple
  '#8a6d2e', // ochre
  '#5e7d3e', // olive
  '#6b3e3e', // wine
  '#3e6b8a', // slate blue
  '#b07a3e', // amber
  '#4e7a5e', // moss
  '#8a4e6b', // rose
  '#6b4e8a', // violet
  '#8a8a3e', // mustard
];

const surnames = [...new Set(ancestors.map((a) => a.surname))].sort();
const surnameColor: Record<string, string> = Object.fromEntries(
  surnames.map((s, i) => [s, palette[i % palette.length]])
);

function placeFor(name: string): PlaceRecord | null {
  if (!name) return null;
  const p = places[name];
  if (!p || p.lat == null || p.lon == null) return null;
  return p;
}

type Point = {
  id: string;
  slug: string;
  name: string;
  surname: string;
  birth: string;
  death: string;
  birth_place: string;
  death_place: string;
  birthLat: number;
  birthLon: number;
  deathLat: number | null;
  deathLon: number | null;
  color: string;
  generation: number;
};

const points: Point[] = ancestors
  .map((a): Point | null => {
    const bp = placeFor(a.birth_place);
    if (!bp) return null;
    const dp = placeFor(a.death_place);
    return {
      id: a.id,
      slug: a.slug,
      name: a.name,
      surname: a.surname,
      birth: a.birth,
      death: a.death,
      birth_place: a.birth_place,
      death_place: a.death_place,
      birthLat: bp.lat as number,
      birthLon: bp.lon as number,
      deathLat: dp ? (dp.lat as number) : null,
      deathLon: dp ? (dp.lon as number) : null,
      color: surnameColor[a.surname] || '#666',
      generation: a.generation,
    };
  })
  .filter((p): p is Point => p !== null);

// Surnames that actually appear on the map (after filtering for geocoded birthplaces)
const mappedSurnames = [...new Set(points.map((p) => p.surname))].sort();

const totalAncestors = ancestors.length;
const mappedCount = points.length;
const skippedCount = totalAncestors - mappedCount;
const countriesShown = new Set(
  points.map((p) => {
    const cleaned = p.birth_place.replace(/\s*\([^)]*\)\s*/g, '').trim();
    const tokens = cleaned.split(',').map((t) => t.trim());
    return tokens[tokens.length - 1] || '?';
  })
);
---

<BaseLayout
  title="Family Map"
  description="Birthplaces of direct ancestors plotted on a map of North America and Europe."
>
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <h1 class="font-serif text-3xl text-[var(--color-dark-brown)] mb-2">Where they came from</h1>
  <p class="text-sm text-[var(--color-warm-gray)] mb-6">
    {mappedCount} of {totalAncestors} direct ancestors plotted by birthplace.
    {skippedCount} have no birthplace recorded.
    Each color is a surname. Lines run from birthplace to death place when both are known.
  </p>

  <div
    id="ancestor-map"
    class="w-full h-[600px] rounded border border-[var(--color-parchment-dark)]"
  ></div>

  <div class="mt-4">
    <h2 class="font-serif text-lg text-[var(--color-dark-brown)] mb-2">Surnames on the map</h2>
    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
      {
        mappedSurnames.map((s) => (
          <button
            type="button"
            data-surname={s}
            class="map-legend-item flex items-center gap-2 hover:opacity-70"
          >
            <span
              class="inline-block w-3 h-3 rounded-full"
              style={`background-color: ${surnameColor[s]}`}
            ></span>
            <span>{s}</span>
          </button>
        ))
      }
    </div>
    <p class="text-xs text-[var(--color-muted)] mt-3">
      Showing birthplaces in {countriesShown.size} countries / regions.
      The Belgian (Mélin) and German (Wittenberg, Daaden) ancestors aren't yet on the map —
      those records exist in the archive but are missing parent links or birthplace fields.
    </p>
  </div>

  <script
    type="application/json"
    id="map-data"
    set:html={JSON.stringify({ points, surnameColor })}
  />

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>

  <script is:inline>
    (function () {
      function escapeHtml(s) {
        return String(s || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function formatYear(d) {
        if (!d) return '';
        const s = String(d);
        const m = s.match(/(\d{4})/);
        return m ? m[1] : s;
      }

      function lifespan(birth, death) {
        const b = formatYear(birth);
        const d = formatYear(death);
        if (b && d) return `${b}–${d}`;
        if (b) return `b. ${b}`;
        if (d) return `d. ${d}`;
        return '';
      }

      function haversineKm(lat1, lon1, lat2, lon2) {
        const R = 6371;
        const toRad = (x) => (x * Math.PI) / 180;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a =
          Math.sin(dLat / 2) ** 2 +
          Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
        return 2 * R * Math.asin(Math.sqrt(a));
      }

      function init() {
        const dataNode = document.getElementById('map-data');
        if (!dataNode || !window.L) return;
        const data = JSON.parse(dataNode.textContent);
        const points = data.points;

        const map = L.map('ancestor-map', {
          worldCopyJump: true,
        });

        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
          attribution:
            '&copy; <a href="https://openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
          subdomains: 'abcd',
          maxZoom: 19,
        }).addTo(map);

        const markersBySurname = {};
        const arcsBySurname = {};
        const allLatLngs = [];

        points.forEach((p) => {
          const popup = `
            <div style="font-family: Georgia, serif; min-width: 180px;">
              <div style="font-size: 1rem; font-weight: 600; color: #3d2e1e;">${escapeHtml(p.name)}</div>
              <div style="font-size: 0.85rem; color: #6b6560; margin-bottom: 4px;">${escapeHtml(lifespan(p.birth, p.death))}</div>
              <div style="font-size: 0.85rem; color: #2c2420;">
                <strong>Born:</strong> ${escapeHtml(p.birth_place)}
              </div>
              ${p.death_place ? `<div style="font-size: 0.85rem; color: #2c2420;"><strong>Died:</strong> ${escapeHtml(p.death_place)}</div>` : ''}
              <div style="font-size: 0.75rem; color: #9a918a; margin-top: 6px;">
                Generation ${p.generation} &middot; ${escapeHtml(p.surname)}
              </div>
              <a href="/person/${escapeHtml(p.slug)}/" style="font-size: 0.85rem; color: #8b6f4e; display: inline-block; margin-top: 6px;">View record →</a>
            </div>
          `;

          const marker = L.circleMarker([p.birthLat, p.birthLon], {
            radius: 6,
            fillColor: p.color,
            color: '#3d2e1e',
            weight: 1,
            opacity: 0.9,
            fillOpacity: 0.85,
          }).bindPopup(popup);

          marker.addTo(map);
          (markersBySurname[p.surname] = markersBySurname[p.surname] || []).push(marker);
          allLatLngs.push([p.birthLat, p.birthLon]);

          // Draw migration arc if death place is known and meaningfully distant
          if (
            p.deathLat != null &&
            p.deathLon != null &&
            haversineKm(p.birthLat, p.birthLon, p.deathLat, p.deathLon) > 50
          ) {
            const arc = L.polyline(
              [
                [p.birthLat, p.birthLon],
                [p.deathLat, p.deathLon],
              ],
              {
                color: p.color,
                weight: 1.5,
                opacity: 0.55,
                dashArray: '4,4',
              }
            );
            arc.addTo(map);
            (arcsBySurname[p.surname] = arcsBySurname[p.surname] || []).push(arc);
            allLatLngs.push([p.deathLat, p.deathLon]);
          }
        });

        if (allLatLngs.length) {
          map.fitBounds(allLatLngs, { padding: [30, 30] });
        } else {
          map.setView([45, -75], 3);
        }

        // Legend toggling: click a surname to hide/show its layers
        const hidden = new Set();
        document.querySelectorAll('.map-legend-item').forEach((btn) => {
          btn.addEventListener('click', () => {
            const surname = btn.getAttribute('data-surname');
            const isHidden = hidden.has(surname);
            const markers = markersBySurname[surname] || [];
            const arcs = arcsBySurname[surname] || [];
            if (isHidden) {
              markers.forEach((m) => m.addTo(map));
              arcs.forEach((a) => a.addTo(map));
              hidden.delete(surname);
              btn.style.opacity = '1';
            } else {
              markers.forEach((m) => map.removeLayer(m));
              arcs.forEach((a) => map.removeLayer(a));
              hidden.add(surname);
              btn.style.opacity = '0.35';
            }
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>
