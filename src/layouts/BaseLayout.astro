---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Family history of the Krumpos, Schmidt, Martin, Coppersmith, and allied families of Wisconsin.' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — krumpos.org</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={`${title} — krumpos.org`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
</head>
<body class="min-h-screen">
  <header class="border-b border-[var(--color-parchment-dark)] bg-[var(--color-parchment)]">
    <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="font-serif text-xl text-[var(--color-dark-brown)] no-underline hover:text-[var(--color-accent)]">
        krumpos.org
      </a>
      <div class="flex gap-6 text-sm">
        <a href="/" class:list={[currentPath === '/' && 'font-semibold']}>Home</a>
        <a href="/narrative" class:list={[currentPath === '/narrative' && 'font-semibold']}>Story</a>
        <a href="/search" class:list={[currentPath === '/search' && 'font-semibold']}>Search</a>
        <a href="/about" class:list={[currentPath === '/about' && 'font-semibold']}>About</a>
      </div>
    </nav>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-8">
    <slot />
  </main>

  <footer class="border-t border-[var(--color-parchment-dark)] mt-16">
    <div class="max-w-3xl mx-auto px-4 py-6 text-sm text-[var(--color-muted)]">
      <p>A family archive maintained by Don Krumpos. Only deceased ancestors are included.</p>
    </div>
  </footer>
</body>
</html>
